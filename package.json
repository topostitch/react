{
  "name": "@topostitch/react",
  "version": "1.0.1",
  "description": "React bindings for TopoStitch.",
  "main": "dist/index.cjs",
  "types": "dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/model-viewer.ts src/renderers.ts --dts --external react --external react-dom --external react/jsx-runtime --external @topostitch/core --external cesium",
    "prepare": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "./model-viewer": {
      "types": "./dist/model-viewer.d.cts",
      "default": "./dist/model-viewer.cjs"
    },
    "./renderers": {
      "types": "./dist/renderers.d.cts",
      "default": "./dist/renderers.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/topostitch/react.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite-plugin-cesium": "^1.2.23"
  },
  "dependencies": {
    "@google/model-viewer": "^4.3.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@topostitch/core": "^0.1.0",
    "aframe": "^1.8.0",
    "cesium": "^1.143.0",
    "three": "^0.183.2"
  }
}
